# Downloaded and locally generated data
data/*
!data/.gitkeep

# Generated analysis outputs
outputs/*
!outputs/.gitkeep

# Local Python environment
.venv/

# Local R environment configuration
.Renviron


#-------------------------------------------------------------------------#
#                                  R                                      #
#-------------------------------------------------------------------------#

.Rhistory
.Rapp.history
.RData
.RDataTmp
.Ruserdata
.Rproj.user/

*_cache/
/cache/
*.utf8.md
*.knit.md


#-------------------------------------------------------------------------#
#                                Python                                   #
#-------------------------------------------------------------------------#

__pycache__/
*.py[codz]
*$py.class
*.so
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/


#-------------------------------------------------------------------------#
#                                Quarto                                   #
#-------------------------------------------------------------------------#

.quarto/

# Rendered HTML, Markdown and their figure folders are intentionally
# not ignored, so they can be published on GitHub.

/.quarto/
**/*.quarto_ipynb
